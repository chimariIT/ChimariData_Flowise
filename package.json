{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development VITE_SEPARATED=true tsx server/index.ts",
    "dev:client": "vite --port 5173",
    "dev:server-only": "cross-env NODE_ENV=development VITE_SEPARATED=true tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc",
    "check:client": "tsc -p tsconfig.check.json",
    "db:push": "drizzle-kit up:pg",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:migrate:project-states": "tsx scripts/apply-project-state-migration.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:ui-comprehensive": "playwright test tests/ui-comprehensive.spec.ts",
    "test:ui-comprehensive-headed": "playwright test tests/ui-comprehensive.spec.ts --headed",
    "test:screenshots": "playwright test tests/ui-comprehensive.spec.ts --project=chromium",
    "test:user-journeys": "playwright test tests/updated-user-journeys.spec.ts --project=chromium",
    "test:user-journeys-headed": "playwright test tests/updated-user-journeys.spec.ts --headed --project=chromium",
    "test:user-journeys-old": "playwright test tests/user-journey-complete.spec.ts --project=chromium",
    "test:ui-screens": "playwright test tests/ui-screens-capture.spec.ts --project=chromium",
    "test:ui-screens-headed": "playwright test tests/ui-screens-capture.spec.ts --headed --project=chromium",
    "test:journey-screenshots": "playwright test tests/user-journey-screenshots.spec.ts --project=chromium",
    "test:journey-screenshots-headed": "playwright test tests/user-journey-screenshots.spec.ts --headed --project=chromium",
    "test:auth": "playwright test tests/auth-smoke.spec.ts --project=chromium",
    "test:auth-headed": "playwright test tests/auth-smoke.spec.ts --headed --project=chromium",
    "test:auth-serial": "playwright test tests/auth-smoke.spec.ts --project=chromium --workers=1",
    "test:auth-headed-serial": "playwright test tests/auth-smoke.spec.ts --headed --project=chromium --workers=1",
    "test:auth-verbose": "PWDEBUG=console playwright test tests/auth-smoke.spec.ts --project=chromium --workers=1 --debug",
    "test:nav": "playwright test tests/nav-smoke.spec.ts --project=chromium",
    "test:nav-serial": "playwright test tests/nav-smoke.spec.ts --project=chromium --workers=1",
    "test:nav-headed": "playwright test tests/nav-smoke.spec.ts --headed --project=chromium",
    "test:nav-headed-serial": "playwright test tests/nav-smoke.spec.ts --headed --project=chromium --workers=1",
    "test:dashboard": "playwright test tests/dashboard-smoke.spec.ts --project=chromium",
    "test:dashboard-serial": "playwright test tests/dashboard-smoke.spec.ts --project=chromium --workers=1",
    "test:dashboard-headed": "playwright test tests/dashboard-smoke.spec.ts --headed --project=chromium",
    "test:dashboard-headed-serial": "playwright test tests/dashboard-smoke.spec.ts --headed --project=chromium --workers=1",
    "test:e2e-agents": "playwright test tests/e2e/agents/multi-agent-upload-flow.test.ts --project=chromium",
    "test:e2e-agents-headed": "playwright test tests/e2e/agents/multi-agent-upload-flow.test.ts --headed --project=chromium",
    "test:e2e-agents-debug": "playwright test tests/e2e/agents/multi-agent-upload-flow.test.ts --debug --project=chromium",
    "test:dashboard-auth": "playwright test tests/dashboard-authenticated.spec.ts --project=chromium",
    "test:dashboard-auth-serial": "playwright test tests/dashboard-authenticated.spec.ts --project=chromium --workers=1",
    "test:dashboard-auth-headed": "playwright test tests/dashboard-authenticated.spec.ts --headed --project=chromium",
    "test:dashboard-auth-headed-serial": "playwright test tests/dashboard-authenticated.spec.ts --headed --project=chromium --workers=1",
    "test:routes-auth": "playwright test tests/protected-routes-authenticated.spec.ts --project=chromium",
    "test:routes-auth-serial": "playwright test tests/protected-routes-authenticated.spec.ts --project=chromium --workers=1",
    "test:routes-auth-headed": "playwright test tests/protected-routes-authenticated.spec.ts --headed --project=chromium",
    "test:routes-auth-headed-serial": "playwright test tests/protected-routes-authenticated.spec.ts --headed --project=chromium --workers=1",
    "test:enhanced-features": "playwright test tests/enhanced-features.spec.ts --project=chromium",
    "test:enhanced-features-headed": "playwright test tests/enhanced-features.spec.ts --headed --project=chromium",
    "test:dynamic-templates": "playwright test tests/dynamic-template-engine.spec.ts --project=chromium",
    "test:dynamic-templates-headed": "playwright test tests/dynamic-template-engine.spec.ts --headed --project=chromium",
    "test:unit": "vitest --config vitest.backend.config.ts run tests/unit/",
    "test:unit-watch": "vitest --config vitest.backend.config.ts tests/unit/",
    "test:unit:storage": "vitest --config vitest.backend.config.ts run tests/unit/storage-relations.test.ts",
    "test:unit:agents": "vitest --config vitest.backend.config.ts run tests/unit/agents/",
    "test:integration": "vitest --config vitest.backend.config.ts run tests/integration/",
    "test:integration:agents": "vitest --config vitest.backend.config.ts run tests/integration/agents/",
    "test:backend": "vitest --config vitest.backend.config.ts run",
    "test:backend-watch": "vitest --config vitest.backend.config.ts",
    "test:client": "vitest --config vitest.config.ts",
    "test:production": "playwright test tests/production-user-journeys.spec.ts --reporter=list,html",
    "test:production-headed": "playwright test tests/production-user-journeys.spec.ts --headed --reporter=list,html",
    "test:production-debug": "playwright test tests/production-user-journeys.spec.ts --debug",
    "test:production-users": "playwright test tests/production-user-journeys.spec.ts --grep \"Production User Journeys\"",
    "test:production-admin": "playwright test tests/production-user-journeys.spec.ts --grep \"Admin Billing\"",
    "test:production-agents": "playwright test tests/production-user-journeys.spec.ts --grep \"Agent & Tool Management\"",
    "test:e2e-tools": "playwright test tests/complete-user-journey-with-tools.spec.ts --project=chromium",
    "test:e2e-tools-headed": "playwright test tests/complete-user-journey-with-tools.spec.ts --headed --project=chromium",
    "test:e2e-tools-debug": "playwright test tests/complete-user-journey-with-tools.spec.ts --debug --project=chromium",
    "cleanup:duplicates": "node scripts/cleanup-duplicates.bat",
    "cleanup:audit": "echo See CODEBASE-AUDIT-AND-CLEANUP.md for full audit report",
    "create-admin": "node scripts/create-admin.js"
  },
