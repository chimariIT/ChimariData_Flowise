{
  "extends": "./tsconfig.json",
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "types/**/*",
    "custom.d.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "server",
    "tests",
    "playwright.config.ts",
    "playwright.config.js",
    "playwright.config.production.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "target": "ES2020"
  }
}
