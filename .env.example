# ChimariData Platform Environment Variables

# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database"

# AI Service Keys
GOOGLE_AI_API_KEY="your_google_ai_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Payment Processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
VITE_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"

# Email Service
SENDGRID_API_KEY="your_sendgrid_api_key"

# Apache Spark Configuration
# For Development (local mode)
SPARK_MASTER_URL="local[*]"
SPARK_APP_NAME="ChimariData-Analytics-Dev"

# For Production (cluster mode) - uncomment and configure these:
# SPARK_MASTER_URL="spark://your-spark-master:7077"
# SPARK_APP_NAME="ChimariData-Analytics-Prod"
# SPARK_HOME="/opt/spark"
# JAVA_HOME="/usr/lib/jvm/java-11-openjdk"

# Spark Resource Configuration
SPARK_EXECUTOR_MEMORY="2g"
SPARK_DRIVER_MEMORY="1g"
SPARK_MAX_CORES="4"
SPARK_MAX_SESSIONS="5"

# Spark Advanced Configuration (optional)
SPARK_PYTHON_PATH="/usr/bin/python3"
SPARK_WAREHOUSE_DIR="./spark-warehouse"
SPARK_CHECKPOINT_DIR="./spark-checkpoints"
SPARK_EVENT_LOG_ENABLED="true"
SPARK_EVENT_LOG_DIR="./spark-events"
SPARK_ENABLE_HIVE="false"

# Spark Java Options (optional)
SPARK_DRIVER_JAVA_OPTS="-XX:+UseG1GC -Dlog4j.configuration=log4j.properties"
SPARK_EXECUTOR_JAVA_OPTS="-XX:+UseG1GC"
SPARK_JAVA_OPTS="-Dspark.sql.adaptive.enabled=true -Dspark.sql.adaptive.coalescePartitions.enabled=true"

# Spark Development/Testing Options
FORCE_SPARK_MOCK="false"
FORCE_SPARK_REAL="false"
PYTHON_PATH="python3"
TEMP_DIR="/tmp"

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"

AZURE_STORAGE_ACCOUNT_NAME="your_azure_account"
AZURE_STORAGE_ACCOUNT_KEY="your_azure_key"

GOOGLE_CLOUD_PROJECT_ID="your_gcp_project"
GOOGLE_CLOUD_CREDENTIALS_PATH="./path/to/credentials.json"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

GITHUB_CLIENT_ID="your_github_oauth_client_id" 
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# Application Settings
PORT=3000
NODE_ENV=production
SESSION_SECRET="your_session_secret_here"

# Performance Monitoring Webhooks (optional)
PERFORMANCE_WEBHOOK_URL="https://your-monitoring-service.com/webhooks/performance"
PERFORMANCE_WEBHOOK_SECRET="your_webhook_secret_for_signature_verification"
ADMIN_EMAIL="admin@yourcompany.com"

# Development only
REPLIT_ENV="true"