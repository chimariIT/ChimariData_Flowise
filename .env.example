# ChimariData Platform Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.development, .env.staging, or .env.production
# 2. Fill in the required values for your environment
# 3. See server/config/environment.ts for environment-specific defaults
#
# BACKEND SELECTION:
# - Python FastAPI Backend (PRIMARY): Port 8000
#   See PYTHON_BACKEND_STARTUP.md for setup instructions
# - Node.js Express Backend (LEGACY): Port 5000
#   Use only for rollback scenarios

# Environment (development | staging | production)
NODE_ENV=development

# ==============================================================================
# BACKEND SELECTION
# ==============================================================================
# Primary backend: Python FastAPI (recommended)
# Set to false to use legacy Node.js Express backend (port 5000)
VITE_USE_PYTHON_BACKEND=true
PYTHON_BACKEND_URL=http://localhost:8000

# Legacy Node.js backend (port 5000) - only for rollback
PORT=5000
HOST=localhost

# ==============================================================================
# DATABASE CONFIGURATION (Shared by both backends)
# ==============================================================================
DATABASE_URL="postgresql://postgres:Chimari0320!@localhost:5432/chimaridata_dev?sslmode=require"
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_TIMEOUT=10000

# Redis Configuration (Optional in dev, Required in staging/production)
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# AI Service Keys (Required - at least one embedding + one LLM provider)
GOOGLE_AI_API_KEY="your_google_ai_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
ENABLE_DEEPAGENT="true"            # Enable LangChain DeepAgent runtime in Python backend
DEEPAGENT_MODEL=""                 # Optional model override (uses backend default when blank)

# Additional AI Providers (Optional)
GROQ_API_KEY=""                    # Groq fast LLM inference (Llama, Mixtral)
TOGETHER_API_KEY=""                # Together AI for Llama embeddings (BGE-large-en-v1.5)
COHERE_API_KEY=""                  # Cohere embeddings (embed-english-v3.0, multilingual)
HUGGINGFACE_API_KEY=""             # HuggingFace Inference API embeddings (GTE, BGE, MiniLM)
OPENROUTER_API_KEY=""              # OpenRouter unified gateway (LLM + embeddings fallback)
OPENROUTER_BASE_URL=""             # Optional override (default: https://openrouter.ai/api/v1)
OPENROUTER_LLM_MODEL=""            # Optional LLM model override (e.g. openai/gpt-4o-mini)
OPENROUTER_HTTP_REFERER=""         # Optional attribution header for OpenRouter requests
OPENROUTER_APP_NAME=""             # Optional attribution app name for OpenRouter requests
TOGETHER_BASE_URL=""               # Optional override (default: https://api.together.xyz/v1)
TOGETHER_LLM_MODEL=""              # Optional LLM model override for Together chat usage
GROQ_BASE_URL=""                   # Optional override (default: https://api.groq.com/openai/v1)
GROQ_LLM_MODEL=""                  # Optional LLM model override for Groq chat usage
OLLAMA_BASE_URL=""                 # Ollama local server (default: http://localhost:11434)
FIRECRAWL_API_KEY=""               # Firecrawl web search for KPI/metric definitions

# Payment Processing (Optional in dev, Required in production)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
VITE_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_signing_secret"

# Email Service (Optional in dev, Required in production)
SENDGRID_API_KEY="your_sendgrid_api_key"
FROM_EMAIL="noreply@chimaridata.com"

# Apache Spark Configuration (Optional in dev, Required in production)
SPARK_ENABLED=false
SPARK_MASTER_URL="local[*]"
SPARK_APP_NAME="ChimariData-Analytics"

# Security Settings (CRITICAL - use strong secrets in production)
SESSION_SECRET="your_session_secret_change_in_production"
JWT_SECRET="your_jwt_secret_change_in_production"
CORS_ORIGIN="http://localhost:5173"

# Feature Flags
ENABLE_DEBUG_LOGGING=true
ENABLE_RATE_LIMITING=false
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION=false

# File Upload
MAX_FILE_SIZE_MB=100
UPLOAD_DIR="./uploads"

# Service Timeouts (in milliseconds)
API_TIMEOUT=30000
PYTHON_SCRIPT_TIMEOUT=300000

# Monitoring & Observability (Optional)
ENABLE_QUERY_LOGGING=false
ENABLE_PERFORMANCE_METRICS=false
SENTRY_DSN="your_sentry_dsn_here"
DATADOG_API_KEY="your_datadog_api_key_here"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="chimaridata-uploads"

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# Microsoft OAuth (Optional)
MICROSOFT_CLIENT_ID="your_microsoft_oauth_client_id"
MICROSOFT_CLIENT_SECRET="your_microsoft_oauth_client_secret"

# Apple OAuth (Optional)
APPLE_CLIENT_ID="your_apple_oauth_client_id"
APPLE_CLIENT_SECRET="your_apple_oauth_client_secret"
